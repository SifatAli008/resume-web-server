{
  "framework": null,
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "vanilla",
  "rewrites": [
    {
      "source": "/resume",
      "destination": "/index.html"
    },
    {
      "source": "/resume/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
