{
  "name": "apps_web_server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node vanilla/server.js",
    "start": "node vanilla/server.js",
    "build:css": "npx @tailwindcss/cli -i ./vanilla/app/tailwind.input.css -o ./vanilla/app/tailwind.generated.css --minify",
    "build": "npm run build:css && npm run build:resume-v2",
    "build:resume-v2": "node scripts/build-resume-v2.mjs",
    "test:static-render": "node vanilla/scripts/static-render-smoke.mjs",
    "test:resume-checklist": "node vanilla/scripts/resume-template-checklist.mjs",
    "test:resume-audit": "node vanilla/scripts/audit-all-templates.mjs",
    "test:resume": "npm run build:resume-v2 && npm run test:static-render && npm run test:resume-v2-checklist",
    "test:resume-v2-checklist": "node vanilla/scripts/resume-v2-checklist.mjs"
  },
  "dependencies": {
    "@sparticuz/chromium-min": "^133.0.0",
    "clsx": "^2.1.1",
    "puppeteer-core": "^24.8.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.1"
  },
  "optionalDependencies": {
    "puppeteer": "^24.8.2"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.6",
    "esbuild": "^0.25.5",
    "tailwindcss": "^4.1.6",
    "typescript": "^5.8.3"
  }
}
